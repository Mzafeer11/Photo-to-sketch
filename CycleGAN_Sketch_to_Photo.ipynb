   "outputs": [],
   "source": [
    "def show(t): return (t.cpu().detach().numpy().transpose(1,2,0)*0.5+0.5).clip(0,1)\n",
    "\n",
    "if 'trainer' in locals():\n",
    "    def fn(img, dir): \n",
    "        t = transform(Image.fromarray(img).convert(\"RGB\")).unsqueeze(0).to(DEVICE)\n",
    "        with torch.no_grad(): out = trainer.G_AB(t) if \"Photo\" in dir else trainer.G_BA(t)\n",
    "        return (show(out.squeeze(0))*255).astype('uint8')\n",
    "    gr.Interface(fn=fn, inputs=[gr.Image(), gr.Radio([\"Sketch -> Photo\", \"Photo -> Sketch\"])], outputs=gr.Image()).launch(share=True)"
   ]
