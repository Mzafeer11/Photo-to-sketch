   "source": [
    "# Domain Adaptation and Unpaired Image-to-Image Translation using CycleGAN\n",
    "\n",
    "**Objective:** Design and implement an unpaired image-to-image translation system using CycleGAN to learn mappings between Sketch and Photo domains.\n",
    "\n",
    "**Platform:** Kaggle (GPU T4 x2 Dual GPU)\n",
    "**Datasets:** Sketchy Database (Downloaded from Google Drive), TU-Berlin, QuickDraw."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 0. Download Dataset from Google Drive\n",
    "This step downloads the official Sketchy Database (approx 4.8GB) and extracts it using 7z."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install gdown\n",
    "!apt-get update && apt-get install p7zip-full -y\n",
    "import os\n",
    "\n",
    "DRIVE_ID = \"0B7ISyeE8QtDdTjE1MG9Gcy1kSkE\"\n",
    "if not os.path.exists(\"sketchy_data.zip\"):\n",
    "    !gdown --id {DRIVE_ID} -O sketchy_data.zip --confirm\n",
    "\n",
    "if not os.path.exists(\"sketchy\"):\n",
    "    !7z x sketchy_data.zip -osketchy\n",
    "    print(\"Extraction complete.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "import torchvision.transforms as transforms\n",
    "from torch.cuda.amp import GradScaler, autocast\n",
    "import itertools\n",
    "import os\n",
    "from PIL import Image\n",
    "import random\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from skimage.metrics import structural_similarity as ssim\n",
    "from skimage.metrics import peak_signal_noise_ratio as psnr\n",
    "import gradio as gr\n",
    "\n",
    "# Configuration\n",
    "IMG_SIZE = 256\n",
    "BATCH_SIZE = 8\n",
    "LR = 0.0002\n",
    "BETAS = (0.5, 0.999)\n",
    "LAMBDA_CYCLE = 10.0\n",
    "LAMBDA_ID = 5.0\n",
    "DEVICE = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "N_RESNET_BLOCKS = 9\n",
    "\n",
    "print(f\"Using device: {DEVICE}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Model Architecture\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class ResNetBlock(nn.Module):\n",
    "    def __init__(self, dim):\n",
    "        super(ResNetBlock, self).__init__()\n",
    "        self.conv_block = nn.Sequential(\n",
    "            nn.ReflectionPad2d(1),\n",
    "            nn.Conv2d(dim, dim, kernel_size=3, padding=0, bias=True),\n",
    "            nn.InstanceNorm2d(dim),\n",
    "            nn.ReLU(True),\n",
    "            nn.ReflectionPad2d(1),\n",
    "            nn.Conv2d(dim, dim, kernel_size=3, padding=0, bias=True),\n",
    "            nn.InstanceNorm2d(dim)\n",
    "        )\n",
    "    def forward(self, x): return x + self.conv_block(x)\n",
    "\n",
    "class ResNetGenerator(nn.Module):\n",
    "    def __init__(self, input_nc=3, output_nc=3, ngf=64, n_blocks=9):\n",
    "        super(ResNetGenerator, self).__init__()\n",
    "        model = [nn.ReflectionPad2d(3), nn.Conv2d(input_nc, ngf, 7, padding=0, bias=True), nn.InstanceNorm2d(ngf), nn.ReLU(True)]\n",
    "        for i in range(2):\n",
    "            mult = 2**i\n",
    "            model += [nn.Conv2d(ngf * mult, ngf * mult * 2, 3, stride=2, padding=1, bias=True), nn.InstanceNorm2d(ngf * mult * 2), nn.ReLU(True)]\n",
    "        mult = 2**2\n",
    "        for _ in range(n_blocks): model += [ResNetBlock(ngf * mult)]\n",
    "        for i in range(2):\n",
    "            mult = 2**(2 - i)\n",
    "            model += [nn.ConvTranspose2d(ngf * mult, int(ngf * mult / 2), 3, stride=2, padding=1, output_padding=1), nn.InstanceNorm2d(int(ngf * mult / 2)), nn.ReLU(True)]\n",
    "        model += [nn.ReflectionPad2d(3), nn.Conv2d(ngf, output_nc, 7, padding=0), nn.Tanh()]\n",
    "        self.model = nn.Sequential(*model)\n",
    "    def forward(self, x): return self.model(x)\n",
    "\n",
    "class PatchGANDiscriminator(nn.Module):\n",
    "    def __init__(self, input_nc=3, ndf=64, n_layers=3):\n",
    "        super(PatchGANDiscriminator, self).__init__()\n",
    "        sequence = [nn.Conv2d(input_nc, ndf, 4, stride=2, padding=1), nn.LeakyReLU(0.2, True)]\n",
    "        nf_mult = 1\n",
    "        for n in range(1, n_layers):\n",
    "            nf_mult_prev, nf_mult = nf_mult, min(2**n, 8)\n",
    "            sequence += [nn.Conv2d(ndf*nf_mult_prev, ndf*nf_mult, 4, stride=2, padding=1), nn.InstanceNorm2d(ndf*nf_mult), nn.LeakyReLU(0.2, True)]\n",
    "        nf_mult_prev, nf_mult = nf_mult, min(2**n_layers, 8)\n",
    "        sequence += [nn.Conv2d(ndf*nf_mult_prev, ndf*nf_mult, 4, stride=1, padding=1), nn.InstanceNorm2d(ndf*nf_mult), nn.LeakyReLU(0.2, True)]\n",
    "        sequence += [nn.Conv2d(ndf*nf_mult, 1, 4, stride=1, padding=1)]\n",
    "        self.model = nn.Sequential(*sequence)\n",
    "    def forward(self, x): return self.model(x)\n",
    "\n",
    "def init_weights(net, init_gain=0.02):\n",
    "    def f(m):\n",
    "        if hasattr(m, 'weight') and (m.__class__.__name__.find('Conv') != -1 or m.__class__.__name__.find('Linear') != -1):\n",
    "            nn.init.normal_(m.weight.data, 0.0, init_gain)\n",
    "            if hasattr(m, 'bias') and m.bias is not None: nn.init.constant_(m.bias.data, 0.0)\n",
    "    net.apply(f)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Data Preparation & Splitting\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class UnpairedDataset(Dataset):\n",
    "    def __init__(self, root_A, root_B, transform=None, split_file_A=None, split_file_B=None, mode='train'):\n",
    "        self.root_A, self.root_B = root_A, root_B\n",
    "        self.transform, self.mode = transform, mode\n",
    "        all_A = self.get_files(root_A)\n",
    "        all_B = self.get_files(root_B)\n",
    "        test_A = self.load_split(split_file_A)\n",
    "        test_B = self.load_split(split_file_B)\n",
    "        \n",
    "        if mode == 'test':\n",
    "            self.files_A = [f for f in all_A if any(ts in f for ts in test_A)]\n",
    "            self.files_B = [f for f in all_B if any(tb in f for tb in test_B)]\n",
    "        else:\n",
    "            self.files_A = [f for f in all_A if not any(ts in f for ts in test_A)]\n",
    "            self.files_B = [f for f in all_B if not any(tb in f for tb in test_B)]\n",
    "            \n",
    "    def load_split(self, f_path):\n",
    "        if not f_path or not os.path.exists(f_path): return []\n",
    "        with open(f_path, 'r') as f:\n",
    "            return [l.strip().replace('.jpg', '').replace('.png', '') for l in f if l.strip() and not l.startswith(('-', 'S'))]\n",
    "\n",
    "    def get_files(self, root):\n",
    "        res = []\n",
    "        for r, _, f in os.walk(root):\n",
    "            for name in f:\n",
    "                if name.lower().endswith(('.png', '.jpg', '.jpeg')): res.append(os.path.join(r, name))\n",
    "        return res\n",
    "\n",
    "    def __getitem__(self, i):\n",
    "        item_A = self.transform(Image.open(self.files_A[i % len(self.files_A)]).convert(\"RGB\"))\n",
    "        item_B = self.transform(Image.open(self.files_B[random.randint(0, len(self.files_B)-1)]).convert(\"RGB\"))\n",
    "        return {\"A\": item_A, \"B\": item_B}\n",
    "    def __len__(self): return max(len(self.files_A), len(self.files_B))\n",
    "\n",
    "transform = transforms.Compose([\n",
    "    transforms.Resize((IMG_SIZE, IMG_SIZE)),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize((0.5,0.5,0.5),(0.5,0.5,0.5))\n",
    "])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Training Engine\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class CycleGANTrainer:\n",
    "    def __init__(self):\n",
    "        self.G_AB = nn.DataParallel(ResNetGenerator(n_blocks=N_RESNET_BLOCKS).to(DEVICE))\n",
    "        self.G_BA = nn.DataParallel(ResNetGenerator(n_blocks=N_RESNET_BLOCKS).to(DEVICE))\n",
    "        self.D_A = nn.DataParallel(PatchGANDiscriminator().to(DEVICE))\n",
    "        self.D_B = nn.DataParallel(PatchGANDiscriminator().to(DEVICE))\n",
    "        \n",
    "        init_weights(self.G_AB); init_weights(self.G_BA); init_weights(self.D_A); init_weights(self.D_B)\n",
    "        self.opt_G = optim.Adam(itertools.chain(self.G_AB.parameters(), self.G_BA.parameters()), lr=LR, betas=BETAS)\n",
    "        self.opt_DA = optim.Adam(self.D_A.parameters(), lr=LR, betas=BETAS)\n",
    "        self.opt_DB = optim.Adam(self.D_B.parameters(), lr=LR, betas=BETAS)\n",
    "        self.crit_GAN, self.crit_Cyc, self.crit_Id = nn.MSELoss(), nn.L1Loss(), nn.L1Loss()\n",
    "        self.scaler_G, self.scaler_DA, self.scaler_DB = GradScaler(), GradScaler(), GradScaler()\n",
    "\n",
    "    def step(self, real_A, real_B):\n",
    "        self.opt_G.zero_grad()\n",
    "        with autocast():\n",
    "            fake_B, fake_A = self.G_AB(real_A), self.G_BA(real_B)\n",
    "            rec_A, rec_B = self.G_BA(fake_B), self.G_AB(fake_A)\n",
    "            loss_GAN = self.crit_GAN(self.D_B(fake_B), torch.ones_like(self.D_B(fake_B))) + \\\n",
    "                       self.crit_GAN(self.D_A(fake_A), torch.ones_like(self.D_A(fake_A)))\n",
    "            loss_Cyc = (self.crit_Cyc(rec_A, real_A) + self.crit_Cyc(rec_B, real_B)) * LAMBDA_CYCLE\n",
    "            loss_Id = (self.crit_Id(self.G_BA(real_A), real_A) + self.crit_Id(self.G_AB(real_B), real_B)) * LAMBDA_ID\n",
    "            loss_G = loss_GAN + loss_Cyc + loss_Id\n",
    "        self.scaler_G.scale(loss_G).backward()\n",
    "        self.scaler_G.step(self.opt_G); self.scaler_G.update()\n",
    "        \n",
    "        for opt, D, real, fake, scaler in [(self.opt_DA, self.D_A, real_A, fake_A, self.scaler_DA), \n",
    "                                           (self.opt_DB, self.D_B, real_B, fake_B, self.scaler_DB)]:\n",
    "            opt.zero_grad()\n",
    "            with autocast():\n",
    "                loss_D = (self.crit_GAN(D(real), torch.ones_like(D(real))) + \\\n",
    "                          self.crit_GAN(D(fake.detach()), torch.zeros_like(D(fake)))) * 0.5\n",
    "            scaler.scale(loss_D).backward()\n",
    "            scaler.step(opt); scaler.update()\n",
    "        return loss_G.item(), loss_D.item(), loss_Cyc.item()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Main Training Loop with Checkpointing\n",
    "Run this cell to start or resume training."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "SKETCH_ROOT = \"sketchy/sketchy/sketches\"\n",
    "PHOTO_ROOT = \"sketchy/sketchy/photos\"\n",
    "TEST_IMG = \"sketchy/test_img.txt\"\n",
    "TEST_SKETCH = \"sketchy/test_sketch.txt\"\n",
    "CHECKPOINT_PATH = \"/kaggle/working/cyclegan_checkpoint.pth\"\n",
    "\n",
    "if os.path.exists(SKETCH_ROOT):\n",
    "    # Initialize Dataset and Loader\n",
    "    train_ds = UnpairedDataset(SKETCH_ROOT, PHOTO_ROOT, transform=transform, mode='train', \n",
    "                               split_file_A=TEST_SKETCH, split_file_B=TEST_IMG)\n",
    "    loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True, num_workers=2)\n",
    "    \n",
    "    # Initialize Trainer\n",
    "    trainer = CycleGANTrainer()\n",
    "    \n",
    "    history = {\"G\": [], \"D\": [], \"C\": []}\n",
    "    start_epoch = 0\n",
    "\n",
    "    # --- RESUME LOGIC ---\n",
    "    if os.path.exists(CHECKPOINT_PATH):\n",
    "        print(f\"Loading checkpoint from {CHECKPOINT_PATH}...\")\n",
    "        checkpoint = torch.load(CHECKPOINT_PATH)\n",
    "        trainer.G_AB.load_state_dict(checkpoint['G_AB_state'])\n",
    "        trainer.G_BA.load_state_dict(checkpoint['G_BA_state'])\n",
    "        trainer.D_A.load_state_dict(checkpoint['D_A_state'])\n",
    "        trainer.D_B.load_state_dict(checkpoint['D_B_state'])\n",
    "        trainer.opt_G.load_state_dict(checkpoint['opt_G_state'])\n",
    "        trainer.opt_DA.load_state_dict(checkpoint['opt_DA_state'])\n",
    "        trainer.opt_DB.load_state_dict(checkpoint['opt_DB_state'])\n",
    "        history = checkpoint['history']\n",
    "        start_epoch = checkpoint['epoch'] + 1\n",
    "        print(f\"Resuming from epoch {start_epoch}\")\n",
    "    else:\n",
    "        print(\"Starting fresh training session.\")\n",
    "\n",
    "    # --- TRAINING LOOP ---\n",
    "    for epoch in range(start_epoch, 100): # Goal is 100 epochs, but Kaggle will time out sooner\n",
    "        print(f\"\\n--- Epoch {epoch} Start ---\")\n",
    "        for i, batch in enumerate(loader):\n",
    "            real_A, real_B = batch[\"A\"].to(DEVICE), batch[\"B\"].to(DEVICE)\n",
    "            lg, ld, lc = trainer.step(real_A, real_B)\n",
    "            history[\"G\"].append(lg); history[\"D\"].append(ld); history[\"C\"].append(lc)\n",
    "            \n",
    "            if i % 100 == 0:\n",
    "                print(f\"[Epoch {epoch}][Batch {i}/{len(loader)}] Loss G: {lg:.4f} | Loss D: {ld:.4f} | Loss Cyc: {lc:.4f}\")\n",
    "        \n",
    "        # --- SAVE CHECKPOINT ---\n",
    "        print(f\"Saving checkpoint at the end of epoch {epoch}...\")\n",
    "        torch.save({\n",
    "            'epoch': epoch,\n",
    "            'G_AB_state': trainer.G_AB.state_dict(),\n",
    "            'G_BA_state': trainer.G_BA.state_dict(),\n",
    "            'D_A_state': trainer.D_A.state_dict(),\n",
    "            'D_B_state': trainer.D_B.state_dict(),\n",
    "            'opt_G_state': trainer.opt_G.state_dict(),\n",
    "            'opt_DA_state': trainer.opt_DA.state_dict(),\n",
    "            'opt_DB_state': trainer.opt_DB.state_dict(),\n",
    "            'history': history,\n",
    "        }, CHECKPOINT_PATH)\n",
    "        print(f\"Epoch {epoch} completed and checkpoint saved successfully.\")\n",
    "else:\n",
    "    print(\"Datasets missing. Please run the download cell first.\")"
   ]
  },
  {
